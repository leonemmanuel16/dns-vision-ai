# DNS Vision AI - Configuración Actualizada (Marzo 2026)
# Instalación limpia con Ultralytics 8.4.24 + YOLO11

# ═══ SISTEMA ═══
EVENTS_DIR=/home/manny/dns-vision-ai/events
BANK_DIR=/home/manny/dns-vision-ai/image_bank
LOGS_DIR=/home/manny/dns-vision-ai/logs
CONFIG_DIR=/home/manny/dns-vision-ai/config

# ═══ CÁMARA PRINCIPAL ═══
CAMERA_IP=192.168.8.26
CAMERA_USER=dns
CAMERA_PASS=admin12345
CAMERA_NAME=hikvision_principal

# ═══ CÁMARA FISHEYE ═══
FISHEYE_IP=192.168.8.64
FISHEYE_USER=dns
FISHEYE_PASS=admin12345
FISHEYE_NAME=hikvision_fisheye

# ═══ DETECCIÓN DE MOVIMIENTO ═══
MOTION_THRESHOLD=8000
FISHEYE_MOTION_THRESHOLD=8000
COOLDOWN_SECONDS=15
FISHEYE_COOLDOWN=15
CHECK_INTERVAL=1.5
FISHEYE_CHECK_INTERVAL=1.5
RESIZE_WIDTH=640
FISHEYE_RESIZE_WIDTH=640

# ═══ AZURE AI (Opcional) ═══
USE_AZURE_VALIDATION=false
USE_YOLO_VALIDATION=true
AZURE_KEY=8SB6MDrRYgBJWAfbybO26TJQydLNJAfkWkzX0DLMZGupoo6HR6bJJQQJ99CCACYeBjFXJ3w3AAAFACOGp3iM
AZURE_ENDPOINT=https://dnsvisionprodemo.cognitiveservices.azure.com/
MIN_PERSON_CONFIDENCE=0.55

# ═══ ALERTAS WHATSAPP ═══
SEND_MOTION_FRAME_WHATSAPP=true
FISHEYE_SEND_WHATSAPP=true
ALERT_ONLY_IF_AZURE_PERSON=true

# ═══ YOLO IA ═══
YOLO_MODEL=yolo11n.pt
YOLO_CONF_THRESHOLD=0.5
YOLO_DEVICE=cpu

# ═══ DASHBOARD ═══
PUBLISH_DASHBOARD_EVENTS=true
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=3000

# ═══ VERSIÓN ═══
DNS_VISION_VERSION=2.0.0-2026.03.20
ULTRALYTICS_VERSION=8.4.24
PYTHON_VERSION=3.12
INSTALLATION_DATE=2026-03-20-23:24